LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

APP_ENV=development
APP_NAME=Semiconductor MRP Demo
API_PREFIX=/api

# 可选；不设则使用 backend/app/config.py 中的默认 SQLite 路径
# DATABASE_URL=sqlite:///.../backend/mrp.db
# pydantic-settings 对列表型字段需 JSON 数组格式
# 浏览器访问的前端 Origin 须在此列表中，否则上传等请求会被 CORS 拦截（Next 常用 3000；端口被占用时可能是 3001）
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000","http://127.0.0.1:3001"]
